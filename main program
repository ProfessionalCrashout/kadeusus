# ‚ĒÄ‚ĒÄ login flow ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
def login(db):
    print("\n  ‚ĒÄ‚ĒÄ Existing Patient Login ‚ĒÄ‚ĒÄ")
    print(f"  {DIM}Use your Patient ID and last name to log in.{RESET}\n")

    while True:
        pid = input("  Patient ID:   ").strip()
        if pid.lower() == 'q':
            return None

        match = [p for p in db if p.get("Patient_ID") == pid]
        if not match:
            print("  Patient ID not found. Try again or type 'q' to go back.\n")
            continue

        patient = match[0]
        last = input("  Last Name:    ").strip().lower()
        if last == 'q':
            return None

        if patient.get("Last_Name", "").lower() != last:
            print("  Last name does not match. Try again.\n")
            continue

        print(f"\n  {BOLD}Welcome back, {patient.get('First_Name', 'Patient')}!{RESET}")
        return patient

# ‚ĒÄ‚ĒÄ new patient intake ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
def new_patient_intake():
    first = input("enter your first name:  ").strip()
    if first.lower() == 'q':
        return None

    last = input("enter your last name:  ").strip()
    if last.lower() == 'q':
        return None

    while True:
        age_input = input("Enter your age: ").strip()
        if age_input.lower() == 'q':
            return None
        try:
            age = int(age_input)
            if age <= 0:
                print("Age must be positive. Try again.")
                continue
            break
        except ValueError:
            print("invalid age. please enter a number")

    gender = input("enter your gender (Male / Female / Non-Binary): ").strip()
    if gender.lower() == 'q':
        return None

    while True:
        num_input = input("How many injuries are you reporting? (1-3): ").strip()
        if num_input.lower() == 'q':
            return None
        try:
            n = int(num_input)
            if 1 <= n <= 3:
                break
            print("Please enter a number between 1 and 3.")
        except ValueError:
            print("invalid input. please enter a number")

    injuries = []
    for i in range(1, n + 1):
        print(f"\n  -- Injury {i} of {n} --")
        while True:
            inj = input(f"  describe injury {i}:  ").strip()
            if inj.lower() == 'q':
                return None
            if inj:
                break
            print("  injury description cannot be empty.")

        while True:
            iv = input("  intensity (1=Minimal  2=Minor  3=Moderate  4=Severe  5=Critical):  ").strip()
            if iv.lower() == 'q':
                return None
            try:
                intensity = int(iv)
                if 1 <= intensity <= 5:
                    break
                print("  please enter a number between 1 and 5.")
            except ValueError:
                print("  invalid input. please enter a number")

        r = ai_ref(inj, intensity)
        injuries.append(r)
        cprint(f"  > {r['color']} -- {r['label']} (Priority: {r['priority']})", r["color"])
        if r["matched"]:
            print(f"    AI flagged: {', '.join(r['matched'])}")

    overall = TRIAGE[max(r["effective_intensity"] for r in injuries)]
    return {
        "first": first,
        "last": last,
        "age": age,
        "gender": gender,
        "injuries": injuries,
        "overall": overall
    }

# ‚ĒÄ‚ĒÄ main ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
def run_survey():
    responses = []
    db = load_db()

    print(f"\n{BOLD}Welcome to the general caduceus overview{RESET}")
    print("Type 'q' at any time to quit.\n")

    while True:
        print(f"{BOLD}‚ĒÄ‚ĒÄ‚ĒÄ Main Menu ‚ĒÄ‚ĒÄ‚ĒÄ{RESET}")
        print("  1. Existing patient login")
        print("  2. New patient intake")
        print("  q. Quit\n")

        choice = input("Select an option: ").strip().lower()
        if choice == 'q':
            break

        if choice == '1':
            row = login(db)
            if row is None:
                continue
            print_profile(row, from_db=True)

        elif choice == '2':
            data = new_patient_intake()
            if data is None:
                continue
            print_profile(data, injuries=data["injuries"], overall=data["overall"], from_db=False)

            record = {
                "record_id": f"CDX-{datetime.now().strftime('%Y%m%d%H%M%S')}",
                "timestamp": datetime.now().isoformat(),
                "patient": {
                    "first_name": data["first"],
                    "last_name": data["last"],
                    "age": data["age"],
                    "gender": data["gender"]
                },
                "injuries": data["injuries"],
                "overall_triage": data["overall"],
                "ui_meta": {
                    "badge_color": data["overall"]["hex"],
                    "alert_level": data["overall"]["color"],
                    "injury_count": len(data["injuries"])
                },
            }
            responses.append(record)

        else:
            print("  Invalid option. Enter 1, 2, or q.\n")
            continue

        again = input("Return to main menu? (y/n):  ").strip().lower()
        if again != 'y':
            break

    if responses:
        with open("caduceus_output.json", "w") as f:
            json.dump(responses, f, indent=2)
        print(f"\n{len(responses)} new record(s) saved to caduceus_output.json")

    print("\nThank you for using the Caduceus Overview. Goodbye.\n")
    return responses


if __name__ == "__main__":
    run_survey()
