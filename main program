# ‚ĒÄ‚ĒÄ triage config ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
TRIAGE = {
    1: {"color": "RED",    "hex": "#D50000", "label": "Critical",  "priority": "Immediate"},
    2: {"color": "RED",    "hex": "#D50000", "label": "Severe",    "priority": "High"},
    3: {"color": "ORANGE", "hex": "#FF6D00", "label": "Moderate",  "priority": "Medium"},
    4: {"color": "YELLOW", "hex": "#FFD600", "label": "Minor",     "priority": "Low"},
    5: {"color": "YELLOW", "hex": "#FFD600", "label": "Minimal",   "priority": "Very Low"},
}

RISK = {
    "fracture": 2, "break": 2, "laceration": 3, "bruise": 5, "sprain": 4,
    "strain": 4,   "burn": 2,  "concussion": 1, "dislocation": 3, "cut": 4,
    "abrasion": 5, "contusion": 4, "puncture": 3, "crush": 1, "nerve": 2,
    "head": 1,     "spine": 1, "chest": 2, "abdomen": 3, "shoulder": 3,
    "knee": 4,     "ankle": 4, "wrist": 4, "finger": 5,
}

ANSI  = {"RED": "\033[91m", "ORANGE": "\033[33m", "YELLOW": "\033[93m"}
BOLD  = "\033[1m";  DIM = "\033[2m";  WHITE = "\033[97m";  RESET = "\033[0m"

DB_PATH = "Simulated Patient Data w_traveltime.csv"

# ‚ĒÄ‚ĒÄ helpers ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
def cprint(text, color, bold=False):
    print(f"{BOLD if bold else ''}{ANSI.get(color,'')}{text}{RESET}")

def ai_ref(injury_name, user_int):
    low = injury_name.lower()
    matched, risk = [], 0

    for kw, r in RISK.items():
        if kw in low:
            matched.append(kw)
            risk = max(risk, r)

    # Always blend user intensity and AI risk
    eff = max(1, min(5, round(0.6 * user_int + 0.4 * risk)))

    t = TRIAGE[eff]
    return {
        "injury": injury_name,
        "user_intensity": user_int,
        "ai_risk": risk,
        "effective_intensity": eff,
        "matched": matched,
        "color": t["color"],
        "label": t["label"],
        "priority": t["priority"]
    }

def load_db():
    patients = []
    try:
        with open(DB_PATH, newline='', encoding='utf-8') as f:
            reader = csv.DictReader(f)
            for row in reader:

                # DOB
                dob_raw = row.get("DOB")
                try:
                    row["DOB"] = parser.parse(dob_raw) if dob_raw else None
                except:
                    row["DOB"] = None

                # Arrival time
                at_raw = row.get("Arrival_Time")
                try:
                    row["Arrival_Time"] = parser.parse(at_raw) if at_raw else None
                except:
                    row["Arrival_Time"] = None

                # Triage level
                try:
                    row["Triage_Level"] = int(str(row.get("Triage_Level", "")).strip())
                except:
                    row["Triage_Level"] = 3  # safe default

                patients.append(row)

    except FileNotFoundError:
        print("\nERROR: Database file not found. Continuing without DB.\n")

    return patients

def calc_age(dob):
    if not dob:
        return "Unknown"
    today = datetime.today()
    return today.year - dob.year - ((today.month, today.day) < (dob.month, dob.day))

